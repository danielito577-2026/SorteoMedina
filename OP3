<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>¡Rifa Egresados 2026! 🌴</title>
    <style>
        body { 
            font-family: 'Comic Sans MS', 'Chalkboard SE', sans-serif; 
            background-color: #e0f7fa; 
            color: #006064; 
            padding: 15px; 
            margin: 0;
        }
        .container { 
            background: white; 
            padding: 25px; 
            border-radius: 40px 15px 40px 15px; 
            max-width: 500px; 
            margin: auto; 
            box-shadow: 0 10px 0px #4dd0e1;
            border: 4px solid #4dd0e1;
        }
        h1 { color: #ff1744; font-size: 28px; margin-bottom: 5px; text-shadow: 2px 2px #ffcc80; text-align: center; }
        .subtitulo { color: #00bcd4; font-weight: bold; margin-bottom: 25px; display: block; font-size: 16px; text-align: center; }

        .info-box { 
            background: #fff9c4; 
            border-radius: 25px; 
            padding: 20px; 
            margin-bottom: 25px; 
            text-align: left; 
            border: 3px dashed #fdd835;
        }
        .pago-info { 
            background: #ffffff; 
            border-radius: 20px; 
            padding: 15px; 
            margin-top: 15px; 
            border: 3px solid #ff1744; 
            text-align: center;
        }

        .alias-click { 
            color: #ffffff; 
            font-weight: bold; 
            cursor: pointer; 
            background: #ff1744; 
            padding: 8px 20px; 
            border-radius: 50px;
            display: inline-block;
            margin-top: 10px;
            box-shadow: 0 4px 0 #b71c1c;
        }
        #copiado-aviso { font-size: 14px; color: #43a047; display: none; margin-top: 8px; font-weight: bold; }

        .grilla { display: grid; grid-template-columns: repeat(auto-fill, minmax(48px, 1fr)); gap: 12px; margin: 25px 0; min-height: 100px; }
        .nro { 
            width: 48px; height: 48px;
            display: flex; align-items: center; justify-content: center;
            background: #b2ebf2; color: #006064;
            border-radius: 50%; cursor: pointer; font-weight: bold; 
            transition: 0.3s; box-shadow: 0 4px 0 #4dd0e1;
        }
        .nro.reservado { background: #eeeeee; color: #bdbdbd; cursor: not-allowed; text-decoration: line-through; box-shadow: none; }
        .nro.seleccionado { 
            background: #ffeb3b; color: #333; 
            transform: scale(1.1) rotate(-5deg);
            border: 2px solid #000;
            box-shadow: 4px 4px 0 #fbc02d;
        }
        
        #form-reserva { 
            display: none; margin-top: 25px; padding: 20px; 
            background: #f1f8e9; border-radius: 30px; border: 4px solid #8bc34a;
        }
        input { padding: 12px; width: 85%; margin-bottom: 15px; border: 2px solid #8bc34a; border-radius: 15px; font-size: 16px; }
        button { background: #00c853; color: white; border: none; padding: 15px; border-radius: 20px; cursor: pointer; font-weight: bold; width: 100%; font-size: 18px; box-shadow: 0 6px 0 #1b5e20; }

        .footer { margin-top: 40px; color: #00838f; font-size: 14px; text-align: center; }
        .fecha-sorteo { background: #00bcd4; color: white; padding: 10px 25px; border-radius: 50px; display: inline-block; margin: 15px 0; }
    </style>
</head>
<body>

<div class="container">
    <h1>🌴 RIFA EGRESADOS 🌴</h1>
    <span class="subtitulo">¡Ayudanos a viajar! ✈️☀️</span>

    <div class="info-box">
        <h2 style="text-align:center; color:#f57f17; margin-top:0;">🔥 Premios</h2>
        <div>🥇 1er: Lechón al horno de barro 🍖</div>
        <div>🥈 2do: 5 kg de asado 🥩</div>
        <div>🥉 3er: Un clavo oxidado 🔨</div>
        
        <div class="pago-info">
            <span style="font-weight:bold; color:#ff1744; font-size:20px;">🎟 PRECIO: $5000</span><br>
            <div class="alias-click" onclick="copiarAlias('mieltresreinas.nx')">mieltresreinas.nx</div>
            <div id="copiado-aviso">¡Copiado! 📋✨</div>
        </div>
    </div>

    <p style="text-align:center;"><b>✨ ELEGÍ TU NÚMERO:</b></p>
    <div id="grilla" class="grilla">Cargando números... ⏳</div>

    <div id="form-reserva">
        <h3 style="text-align:center;">🎉 NÚMERO <span id="nro-elegido" style="color:#ff1744"></span> 🎉</h3>
        <input type="text" id="nombre-cliente" placeholder="¿Tu nombre?">
        <input type="tel" id="tel-cliente" placeholder="Tu WhatsApp">
        <button id="btn-confirmar" onclick="enviarReserva()">¡RESERVAR YA! 🚀</button>
    </div>

    <div class="footer">
        <div class="fecha-sorteo">📅 SORTEO: 31/03/2026 - 11hs</div>
        <p>Todo lo recaudado es para nuestro viaje de egresados. 🎓<br><b>¡Suerte para todos! 🍀</b></p>
    </div>
</div>

<script>
    const scriptURL = 'https://script.google.com/macros/s/AKfycbxp31A5qhqfKD4B7mtUc6Buo9thq30k6SESxbi4pRMrKTKU0QwOMTgS2vTX8xrlCnjY/exec';
    const miWhatsApp = "5492995304691"; 
    let numeroSeleccionado = null;

    function copiarAlias(texto) {
        navigator.clipboard.writeText(texto).then(() => {
            const aviso = document.getElementById('copiado-aviso');
            aviso.style.display = 'block';
            setTimeout(() => { aviso.style.display = 'none'; }, 2000);
        });
    }

    async function cargarNumeros() {
        try {
            // Usamos un método de 'cache: no-store' para forzar la carga limpia
            const response = await fetch(scriptURL, { method: 'GET', cache: 'no-store' });
            if (!response.ok) throw new Error('Error en red');
            const data = await response.json();
            
            const grilla = document.getElementById('grilla');
            grilla.innerHTML = '';
            
            // Empezamos desde i=1 para saltar el encabezado del Excel
            for (let i = 1; i < data.length; i++) {
                const nro = data[i][0];
                const estado = data[i][2];
                const div = document.createElement('div');
                div.className = 'nro' + (estado === 'Reservado' ? ' reservado' : '');
                div.innerText = nro;
                
                if (estado !== 'Reservado') {
                    div.onclick = () => {
                        document.querySelectorAll('.nro').forEach(el => el.classList.remove('seleccionado'));
                        div.classList.add('seleccionado');
                        numeroSeleccionado = nro;
                        document.getElementById('nro-elegido').innerText = nro;
                        document.getElementById('form-reserva').style.display = 'block';
                        document.getElementById('form-reserva').scrollIntoView({ behavior: 'smooth' });
                    };
                }
                grilla.appendChild(div);
            }
        } catch (error) {
            console.error(error);
            document.getElementById('grilla').innerHTML = "<p style='grid-column: 1/-1; color:red;'>Error al conectar. Por favor, refrescá la página o verificá tu conexión.</p>";
        }
    }

    async function enviarReserva() {
        const nombre = document.getElementById('nombre-cliente').value;
        const telefono = document.getElementById('tel-cliente').value;
        if (!nombre || !telefono) return alert("Completá tus datos.");

        const btn = document.getElementById('btn-confirmar');
        btn.innerText = "RESERVANDO...";
        btn.disabled = true;

        const msj = encodeURIComponent(`¡Hola! Soy ${nombre}, reservé el N° ${numeroSeleccionado}. Adjunto comprobante. 🏖️`);
        const urlWa = `https://wa.me/${miWhatsApp}?text=${msj}`;

        try {
            await fetch(scriptURL, {
                method: 'POST',
                mode: 'no-cors', // Importante para Google Apps Script
                body: JSON.stringify({ numero: numeroSeleccionado, nombre: nombre, telefono: telefono })
            });
            window.open(urlWa, '_blank');
            alert("¡Número guardado!");
            location.reload();
        } catch (e) {
            alert("Error al guardar.");
            btn.disabled = false;
        }
    }

    // Iniciamos la carga
    window.onload = cargarNumeros;
</script>
</body>
</html>
